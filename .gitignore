# ===== TERRAFORM IGNORE PATTERNS =====

# Local .terraform directories and cache
.terraform/
.terraform.lock.hcl

# Terraform state files (contain sensitive data)
*.tfstate
*.tfstate.*
*.tfstate.backup
terraform.tfstate.d/

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Terraform plan files
*.tfplan
*.tfplan.*
tfplan
plan.out
plan.json

# Terraform crash log files
crash.log
crash.*.log

# Terraform override files (local customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock files (transient)
.terraform.tfstate.lock.info

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Terraform workspace files
.terraform.workspace

# Terraform graph output files
*.dot
*.svg
*.png

# Terraform module cache
.terraform.modules/

# Terraform provider cache
.terraform/providers/

# Terraform plugin cache
.terraform/plugin-cache/

# Terraform temporary files
*.tmp
*.temp
.terraform.tmp/

# Terraform backup files
*.backup
*.bak

# Terraform log files
*.log
terraform.log

# Terraform debug files
TF_LOG*
terraform-debug.log

# Terraform validation cache
.terraform/validation/

# Terraform format backup files
*.tf.backup

# Terraform import files
import.tf

# Terraform destroy plan files
destroy.tfplan
destroy.plan

# Terraform apply log files
apply.log
destroy.log

# Terraform state migration files
*.tfmigrate

# Terraform workspace directories
terraform.tfstate.d/

# Terraform environment files
.env.terraform
.terraform.env

# Terraform lock files for modules
.terraform.lock.hcl.*

# Terraform generated files
generated/
.generated/

# Terraform test files (if using terraform test)
*.tftest.hcl.json
tests/*.tftest.hcl.json

# ===== END TERRAFORM IGNORE PATTERNS =====

# ===== MACOS SYSTEM FILES =====

# .DS_Store files created by macOS Finder
.DS_Store
.DS_Store?
._*

# Thumbnails created by macOS
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# macOS folder attributes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ===== END MACOS SYSTEM FILES =====