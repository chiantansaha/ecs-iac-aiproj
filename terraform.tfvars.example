tags = {
  app = "AWSUGSGAPP"
}

# Existing VPC infrastructure (subnets auto-discovered by tags)
vpc_id = "vpc-12345678"

# Restrict web interface access to specific IP addresses
# Replace with your actual IP addresses/CIDR blocks
allowed_ips = [
  "203.0.113.0/24",    # Example office network
  "198.51.100.5/32",   # Example specific IP
  "192.0.2.0/24"       # Example home network
]

# AgentCore Configuration
# Enable VPC mode for AgentCore agents (default: true)
enable_agentcore_vpc_mode = true

# Optional: Custom AgentCore agents configuration
# If not specified, uses module defaults (aws_docs_agent, aws_blog_agent, orchestrator_agent)
# agentcore_agents = {
#   custom_agent = {
#     name        = "custom_agent"
#     description = "Custom agent description"
#     entrypoint  = "agents/custom_agent/agent.py"
#   }
# }

# Optional: Custom AgentCore memory configuration
# If not specified, uses module defaults
# agentcore_memory_config = {
#   name              = "custom_memory"
#   description       = "Custom memory configuration"
#   event_expiry_days = 30
#   strategies = [{
#     type        = "semanticMemoryStrategy"
#     name        = "custom_semantic"
#     description = "Custom semantic memory"
#     namespaces  = ["conversations/{sessionId}"]
#   }]
# }

# Optional: ACM certificate ARN for HTTPS support
acm_certificate_arn = "arn:aws:acm:<region>:<account-id>:certificate/<certificate-id>"

# ALB Logging Configuration
alb_access_logs_enabled = true
alb_connection_logs_enabled = true

# Cost optimization: ALB minimum capacity units (10 = 60% savings)
alb_minimum_capacity_units = 10

# ALB Performance Configuration
alb_idle_timeout         = 60
enable_alb_waf_fail_open = false

# ECS Runtime Platform (X86_64 or ARM64)
# ARM64 provides 20% cost savings and better performance per watt
ecs_runtime_platform = "X86_64"  # Change to "ARM64" for Graviton2/3

# ECS Advanced Features
enable_ecs_container_insights      = true   # Enable for production monitoring
enable_ecs_dual_stack_ipv6         = false  # Enable for IPv6 support
ecs_availability_zone_rebalancing  = "ENABLED"

# Cost optimization: CloudWatch log retention (days)
log_retention_days = 7

# MCP Server Configuration
project_name = "aws-assistant"
environment = "development"
service_version = "1.0.0"
log_level = "INFO"

# Enable X-Ray tracing
enable_xray_tracing = true

# CloudWatch Monitoring
# cloudwatch_alarm_actions = ["arn:aws:sns:us-east-1:123456789012:alerts"]